    "almacen_8x8_media": [
      "S...X...",
      ".XX.X.X.",
      "...X...R",
      "X.XXX.X.",
      "..R...X.",
      ".X.X.X..",
      ".X...R..",
      "...XX..G"
    ],
    "almacen_10x10_alta": [
      "S..X......",
      ".X.X.XXX..",
      ".X...R....",
      ".XXX.XXXX.",
